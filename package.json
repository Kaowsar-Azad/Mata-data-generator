{
  "name": "matadata",
  "description": "Professional microstock metadata and background removal engine",
  "author": "MetadataPro Studio",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"node server/index.js\" \"vite --force\"",
    "server": "node server/index.js",
    "app:dev": "concurrently \"node server/index.js\" \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "app:build": "vite build && electron-builder",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui"
  },
  "build": {
    "appId": "com.imagemetadata.app",
    "productName": "Image Metadata Create",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "dist-electron"
    },
    "asarUnpack": [
      "node_modules/exiftool-vendored.pl/**/*",
      "node_modules/exiftool-vendored.exe/**/*",
      "node_modules/exiftool-vendored.mac/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@gradio/client": "^2.2.0",
    "@huggingface/transformers": "^4.2.0",
    "@imgly/background-removal-node": "^1.4.5",
    "@neplex/vectorizer": "^0.0.5",
    "basic-ftp": "^6.0.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "exiftool-vendored": "^35.20.0",
    "express": "^4.21.2",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "framer-motion": "^12.38.0",
    "imagetracerjs": "^1.2.6",
    "keytar": "^7.9.0",
    "lucide-react": "^1.7.0",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.18.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.34.5",
    "ssh2-sftp-client": "^12.1.1",
    "svg-to-pdfkit": "^0.1.8",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^22.1.0",
    "vite": "^8.0.4",
    "vitest": "^0.34.6",
    "wait-on": "^7.2.0"
  }
}
